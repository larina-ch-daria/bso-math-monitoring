*.csv
raw/
data/
*raw*.csv
*LongData*.csv
*Список*.csv
*Структура*.csv
*Результаты*.csv

# Ключи и секреты
.env
.env.*
*secret*
*apikey*
*api_key*
credentials*.json
client_secret*.json
# .clasp.json содержит scriptId — не публикуем
.clasp.json
.clasprc.json

# Служебное
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
build/
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log

